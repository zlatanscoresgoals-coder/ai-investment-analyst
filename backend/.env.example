SEC_USER_AGENT=AIInvestmentAnalyst/0.1 your-email@example.com
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=GoatAnalyst99
AUTO_REFRESH_ENABLED=true
AUTO_REFRESH_INTERVAL_MINUTES=15
RISK_BLOCK_MIN_CONFIDENCE=medium
# Trusted-outlet filter for live investor news on each stock (and legacy alert tooling): comma-separated substrings, lowercase.
CRITICAL_NEWS_STRICT_OUTLETS=true
# Optional: NewsAPI key for domain-filtered headlines (last 10 days) on /recommendations/{ticker}. https://newsapi.org/register
NEWSAPI_KEY=
# CRITICAL_NEWS_ALLOWLIST=reuters,bloomberg,wall street journal,wsj,...
ALERT_WEBHOOK_URL=
# Reliable stock quotes on cloud (Yahoo often blocked). Free tier: https://finnhub.io/register
FINNHUB_API_KEY=
# Railway workaround if deploy fails on "secret Finnhub: not found" — use one of these instead of FINNHUB_API_KEY:
# QUOTE_API_FINNHUB=
# IIA_FINNHUB_TOKEN=
# Optional extra quote fallback (25 requests/day free): https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=
# Optional: https://twelvedata.com/
TWELVE_DATA_API_KEY=
